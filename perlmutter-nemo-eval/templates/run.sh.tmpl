#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck disable=SC1090
source "{{ENV_FILE}}"

cd /tmp

"{{NS_BIN}}" prepare_data \
  --cluster=perlmutter \
  --config_dir="$SCRIPT_DIR" \
  "{{BENCHMARK}}" \
  --data_dir="{{NEMO_SKILLS_DATA_DIR}}"

if [[ "{{JOB_TYPE}}" == "robust_eval" ]]; then
  "{{NS_BIN}}" robust_eval \
    --cluster=perlmutter \
    --config_dir="$SCRIPT_DIR" \
    --server_type=openai \
    --model="{{MODEL}}" \
    --server_address="$OPENAI_BASE_URL" \
    --output_dir="{{MOUNT_OUTPUT_DIR}}" \
    --expname="{{EXPNAME}}" \
    ++benchmarks="{{BENCHMARK}}:{{NUM_SAMPLES}}" \
    ++num_jobs=1 \
    ++skip_filled=True \
    ++max_concurrent_requests="{{MAX_CONCURRENT_REQUESTS}}" \
    ++parse_reasoning=False \
    prompt_set_config=/workspace/prompt_set_config.yaml
else
  "{{NS_BIN}}" eval \
    --cluster=perlmutter \
    --config_dir="$SCRIPT_DIR" \
    --server_type=openai \
    --model="{{MODEL}}" \
    --server_address="$OPENAI_BASE_URL" \
    --output_dir="{{MOUNT_OUTPUT_DIR}}" \
    --expname="{{EXPNAME}}" \
    ++benchmarks="{{BENCHMARK}}:{{NUM_SAMPLES}}" \
    ++skip_filled=True \
    ++max_concurrent_requests="{{MAX_CONCURRENT_REQUESTS}}" \
    ++parse_reasoning=False
fi

touch "{{MOUNT_OUTPUT_DIR}}/eval.done"
